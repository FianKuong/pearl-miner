FROM nvidia/cuda:12.2.0-base-ubuntu22.04

# Minimal CUDA runtime only - no dev tools, no NCCL, no cuDNN
RUN apt-get update && apt-get install -y --no-install-recommends \
    libcurl4 ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pearl-miner /app/pearl-miner
RUN chmod +x /app/pearl-miner

ENTRYPOINT ["sh", "-c", "exec /app/pearl-miner --host ${POOL_HOST:-84.32.220.219:9000} --user ${WALLET}"]
